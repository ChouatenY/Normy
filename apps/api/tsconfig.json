{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@normy-validation/shared": ["../../packages/shared/src/index.ts"],
      "@normy-validation/validation-core": ["../../packages/validation-core/src/index.ts"],
      "@normy-validation/core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
