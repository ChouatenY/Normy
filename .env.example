# =============================================================================
# Normy Environment Variables — copy to .env and fill in your values
# =============================================================================

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://normy:normy@localhost:5432/normy

# ── Redis ──────────────────────────────────────────────────────────────────────
# Required. Redis connection string.
REDIS_URL=redis://localhost:6379

# ── AI Providers ──────────────────────────────────────────────────────────────
# Gemini is the default provider for fresh deployments.
GEMINI_API_KEY=

# Optional provider keys for projects that explicitly choose another provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider to use by default (openai | gemini | anthropic)
AI_PROVIDER=gemini

# ── API Security ───────────────────────────────────────────────────────────────
# Required. Minimum 32 characters. Generate with: openssl rand -base64 32
API_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Dashboard (Next.js public) ─────────────────────────────────────────────────
NEXT_PUBLIC_NORMY_API_URL=http://localhost:3001

# â”€â”€ React live demo (Vite public) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
VITE_NORMY_API_URL=http://localhost:3001
VITE_NORMY_PROJECT_ID=
VITE_NORMY_API_KEY=
