{
  "name": "normy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "docs": "pnpm --filter @normy/docs dev",
    "publish:sdk": "turbo build --filter=@normy-validation/react --filter=@normy/js"
  },
  "devDependencies": {
    "@normy-validation/core": "workspace:*",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.4.0"
}
